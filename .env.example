# Generate with: openssl rand -hex 32
SECRET_KEY=changeme-please-generate-with-openssl-rand-hex-32

# GitHub Personal Access Token (needs repo + workflow scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-username

# Kubernetes (optional — leave empty to use local kubeconfig)
K8S_IN_CLUSTER=false
K8S_KUBECONFIG=

# Database (only if running backend outside Docker)
DATABASE_URL=postgresql+asyncpg://opspilot:opspilot@localhost:5432/opspilot
REDIS_URL=redis://localhost:6379/0
